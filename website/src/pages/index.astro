---
import Layout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout>
  <h1>欢迎来到我的个人博客</h1>
  <p class="muted">这里记录我的 OpenO1 项目日志、Agent 设计思考和推理实验心得。</p>
  <ul>
    <li><a href={`${base}posts/`}>所有文章</a></li>
    <li><a href={`${base}posts/categories/essay/`}>长文 Essays</a></li>
    <li><a href={`${base}posts/categories/note/`}>短想法 Notes</a></li>
    <li><a href={`${base}posts/categories/openo1-log/`}>OpenO1 Logs</a></li>
    <li><a href={`${base}posts/categories/research-note/`}>Research Notes</a></li>
    <li><a href={`${base}posts/categories/principle/`}>Principles</a></li>
  </ul>
</Layout>
